<section class="hero">
  <h1>Welcome to My Recipes</h1>
  <p>Discover fresh ideas for breakfast, lunch, dinner, and cozy snacks in one beautiful place.</p>

  <div class="hero-actions">
    <%= link_to "Explore Recipes", recipes_path, class: "btn btn-primary" %>
    <%= link_to "Learn More", about_path, class: "btn btn-secondary" %>
  </div>
</section>

<section class="section">
  <div class="section-header">
    <h2>Global Recipes</h2>
  </div>

  <div class="card-grid">
    <% @featured_recipes.each do |recipe| %>
      <article class="recipe-card" data-controller="recipe-like" data-recipe-like-recipe-id-value="<%= recipe.id %>">
        <%= link_to recipe_path(recipe), class: "card-link" do %>
          <div class="card-image">🍲</div>
          <div class="card-content">
            <h3><%= recipe.title %></h3>
            <p><%= recipe.description %></p>
            <div class="card-meta">
              <span><%= recipe.category %></span>
              <span><%= recipe.time %></span>
              <span>By <%= recipe.chef.name %></span>
            </div>
            <% if recipe.ingredients.any? %>
              <div class="ingredient-tags">
                <% recipe.ingredients.order(:name).each do |ingredient| %>
                  <span class="ingredient-tag"><%= ingredient.name %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="recipe-like-row">
          <button class="like-button" data-recipe-like-target="button" data-action="click->recipe-like#like" aria-label="Like recipe">
            ❤️ Like
          </button>
          <span class="like-count" data-recipe-like-target="count"><%= recipe.likes_count %></span>
        </div>
      </article>
    <% end %>
  </div>
</section>
