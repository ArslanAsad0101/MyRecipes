<section class="hero">
  <h1>Your Chef Recipes</h1>
  <p>Manage the recipes you created as a chef.</p>
  <p><strong>How to use:</strong> Click “Add New Recipe” to create one, or use “Edit” on any card to update it.</p>
  <div class="hero-actions">
    <%= link_to "Add New Recipe", new_recipe_path, class: "btn btn-primary" %>
  </div>
</section>

<section class="section">
  <div class="section-header">
    <h2>Your Recipes</h2>
  </div>
  <div class="card-grid">
    <% @recipes.each do |recipe| %>
      <article class="recipe-card">
        <%= link_to recipe_path(recipe), class: "card-link", target: "_blank", rel: "noopener" do %>
          <div class="card-image">
            <%= image_tag recipe.image_url, alt: recipe.title, class: "recipe-card-image" %>
          </div>
          <div class="card-content">
            <h3><%= recipe.title %></h3>
            <p><%= recipe.description %></p>
            <div class="card-meta">
              <span><%= recipe.category %></span>
              <span><%= recipe.time %></span>
            </div>
            <% if recipe.ingredients.any? %>
              <div class="ingredient-tags">
                <% recipe.ingredients.order(:name).each do |ingredient| %>
                  <span class="ingredient-tag"><%= ingredient.name %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="card-actions">
          <%= link_to "Edit", edit_recipe_path(recipe), class: "btn btn-secondary" %>
        </div>
      </article>
    <% end %>
  </div>
</section>
