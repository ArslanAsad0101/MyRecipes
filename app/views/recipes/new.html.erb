<section class="section">
  <div class="form-card">
    <h2>Add New Recipe</h2>
    <p>Fill in the recipe details below. Your recipe will be saved and shown on the home page.</p>

    <% if @recipe.errors.any? %>
      <div class="info-card">
        <h3>Please fix these errors:</h3>
        <ul>
          <% @recipe.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @recipe, url: recipes_path, local: true, html: { multipart: true } do |form| %>
      <div class="form-field">
        <%= form.label :title %>
        <%= form.text_field :title %>
      </div>

      <div class="form-field">
        <%= form.label :description %>
        <%= form.text_area :description %>
      </div>

      <div class="form-field">
        <%= form.label :category %>
        <%= form.text_field :category %>
      </div>

      <div class="form-field">
        <%= form.label :time %>
        <%= form.text_field :time %>
      </div>

      <div class="form-field">
        <%= form.label :image_file, "Recipe image" %>
        <%= form.file_field :image_file, accept: "image/*" %>
        <p class="form-help">Upload a photo from your computer, or leave blank to use the default image.</p>
      </div>

      <div class="form-field" data-controller="ingredient-select">
        <%= form.label :ingredient_ids, "Ingredients" %>
        <p class="form-help">Type to search, then hold Ctrl/Cmd to select multiple ingredients.</p>
        <input type="search" data-ingredient-select-target="search" placeholder="Search ingredients..." class="ingredient-search-field" data-action="input->ingredient-select#filter">
        <div class="ingredient-picker">
          <%= form.collection_select :ingredient_ids, Ingredient.order(:name), :id, :name, { include_blank: false }, { multiple: true, size: 8, class: "ingredient-select", data: { ingredient_select_target: "select" } } %>
        </div>
      </div>

      <div class="form-actions">
        <%= form.submit "Create Recipe", class: "btn btn-primary" %>
        <%= link_to "Back to Recipes", recipes_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</section>
