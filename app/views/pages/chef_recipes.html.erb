<section class="hero">
  <h1><%= @chef.name %>'s Recipes</h1>
  <p>Explore the recipes shared by this chef.</p>
</section>

<section class="section">
  <div class="section-header">
    <h2><%= @chef.name %>'s Recipes</h2>
    <%= link_to "Back to Chefs", chefs_path, class: "btn btn-secondary" %>
  </div>

  <% if @recipes.any? %>
    <div class="card-grid">
      <% @recipes.each do |recipe| %>
        <%= render partial: "pages/recipe_card", locals: { recipe: recipe } %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p>This chef has not shared any recipes yet.</p>
    </div>
  <% end %>
</section>
